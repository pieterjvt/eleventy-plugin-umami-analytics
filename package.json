{
    "name": "eleventy-plugin-umami-analytics",
    "version": "1.0.3",
    "description": "An Eleventy plugin for effortless Umami Analytics integration and flexible customization.",
    "keywords": [
        "eleventy",
        "11ty",
        "eleventy-plugin",
        "umami",
        "analytics",
        "script",
        "inject",
        "shortcodes"
    ],
    "homepage": "https://github.com/pieterjvt/eleventy-plugin-umami-analytics",
    "bugs": {
        "url": "https://github.com/pieterjvt/eleventy-plugin-umami-analytics/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/pieterjvt/eleventy-plugin-umami-analytics.git"
    },
    "author": "Pieter van Tienhoven <pieter@pieter.lol> (https://pieter.lol/)",
    "main": "./index.js",
    "exports": {
        ".": "./index.js",
        "./umami": "./src/umami.js"
    },
    "files": [
        "index.js",
        "src/",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "test": "ava",
        "test:watch": "ava --watch",
        "lint": "eslint src/ index.js",
        "lint:fix": "eslint src/ index.js --fix",
        "format": "prettier --write src/ index.js test/",
        "format:check": "prettier --check src/ index.js test/",
        "release": "np"
    },
    "ava": {
        "files": [
            "test/**/*.test.js"
        ]
    },
    "type": "module",
    "license": "MIT",
    "peerDependencies": {
        "@11ty/eleventy": ">=3.0.0",
        "posthtml": "^0.16.7",
        "posthtml-match-helper": "^2.0.3"
    },
    "peerDependenciesMeta": {
        "posthtml": {
            "optional": true
        },
        "posthtml-match-helper": {
            "optional": true
        }
    },
    "devDependencies": {
        "@11ty/eleventy": "^3.1.5",
        "@eslint/js": "^10.0.1",
        "ava": "^8.0.1",
        "eslint": "^10.4.1",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.6.0",
        "posthtml": "^0.16.7",
        "posthtml-match-helper": "^2.0.3",
        "prettier": "^3.8.3"
    }
}
